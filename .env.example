# Copy this file to .env.local and fill in real values.
# Never commit real secrets — this file documents which vars exist, not their values.

# ── Client-side (exposed to the browser, must be prefixed VITE_) ──
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_PAYMENTS_CLIENT_TOKEN=

# ── Supabase (server-side only) ──
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (server-side only, routed through the Lovable connector gateway) ──
STRIPE_SANDBOX_API_KEY=
STRIPE_LIVE_API_KEY=
PAYMENTS_SANDBOX_WEBHOOK_SECRET=
PAYMENTS_LIVE_WEBHOOK_SECRET=
LOVABLE_API_KEY=

# ── Twilio (business-side receptionist number) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Shown to consumers as the number to text for a different service (Phase 3 marketplace)
CONSUMER_TWILIO_PHONE_NUMBER=

# ── AI / data providers ──
ANTHROPIC_API_KEY=
GOOGLE_PLACES_API_KEY=

# ── Monday.com CRM sync (optional — sync calls fail silently if unset) ──
MONDAY_API_KEY=
MONDAY_LEAD_BOARD_ID=
